# ── Baza danych ───────────────────────────────────────────────────────────────
# PostgreSQL (współdzielona baza z swi.campas.pl /home/user/app/obozlog)
DATABASE_URL=postgresql+asyncpg://campas:TWOJE_HASLO@localhost/campas

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUSI być IDENTYCZNY jak w swi.campas.pl (obaj serwisy weryfikują te same tokeny)
JWT_SECRET=wygeneruj-nowy-sekret-openssl-rand-hex-64

# ── Domeny ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://campas.pl
ALLOWED_ORIGINS=https://campas.pl,https://swi.campas.pl

# ── SMTP (Resend) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_TWOJ_KLUCZ_RESEND
SMTP_FROM=noreply@campas.pl

# ── Pliki użytkowników ────────────────────────────────────────────────────────
# Ścieżka wewnątrz Dockera (zamontowany volume)
UPLOAD_DIR=/data/uploads

# ── Robert AI ────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-TWOJ_KLUCZ_DEEPSEEK
JINA_API_KEY=jina_TWOJ_KLUCZ_JINA
